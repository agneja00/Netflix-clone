{
  "version": 2,
  "builds": [
    {
      "src": "vite.config.ts",
      "use": "@vitejs/vercel"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/",
      "headers": {
        "Cache-Control": "public, max-age=0, must-revalidate"
      }
    }
  ],
  "env": {
    "VITE_TMDB_API_KEY": "@tmdb_api_key"
  }
}
